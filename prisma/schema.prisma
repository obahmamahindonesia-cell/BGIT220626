generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  TEST_TAKER
  ADMIN
}

enum Dimension {
  LISTENING
  READING
  SPEAKING
  WRITING
  MEDIATION
  INTEGRATED
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  ESSAY
  AUDIO_RESPONSE
  INTEGRATED_TASK
}

enum QuestionStatus {
  DRAFT
  REVIEW
  PILOT
  ACTIVE
  RETIRED
}

enum CEFRLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum SessionStatus {
  CONFIGURED
  IN_PROGRESS
  SUBMITTED
  SCORED
  COMPLETED
  CANCELLED
  FAILED
}

enum StimulusType {
  TEXT
  AUDIO
  IMAGE
  VIDEO
}

enum BlueprintProduct {
  ACADEMIC
  PROFESSIONAL
  PLACEMENT
  PRACTICE
}

model User {
  id            String   @id @default(uuid())
  supabaseId    String   @unique
  email         String   @unique
  name          String?
  role          UserRole @default(TEST_TAKER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       UserProfile?
  testSessions  TestSession[]
  waitlistEntry Waitlist?
  loginHistory  LoginHistory[]
}

model UserProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  age                 Int?
  profession          String?
  targetLevel         String?
  currentLevel        String?
  testGoals           String[]
  hasPreviousTest     Boolean  @default(false)
  previousTestType    String?
  learningDuration    String?
  estimatedLevel      String?
  preferredDuration   Int      @default(60)
  practiceMode        Boolean  @default(true)
  emailNotifications  Boolean  @default(true)
  technicalCheckPassed Boolean @default(false)
  onboardingCompleted Boolean  @default(false)
  avatarUrl           String?
  displayName         String?
  country             String?
  city                String?
  firstLanguage       String?
  bio                 String?
  institution         String?
  occupation          String?
  focusSkills         String[]
  preferredLanguage   String   @default("id")
  timezone            String?
  certificateVisibility String @default("private")
  productUpdates      Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model QuestionStimulus {
  id        String       @id @default(uuid())
  type      StimulusType @default(TEXT)
  title     String?
  content   String?
  assetUrl  String?
  transcript String?
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  questions QuestionItem[]
}

model QuestionRubric {
  id         String    @id @default(uuid())
  name       String?
  dimension  Dimension?
  level      CEFRLevel?
  criteria   Json?
  maxScore   Int       @default(10)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  questions  QuestionItem[]
}

model QuestionItem {
  id             String         @id @default(uuid())
  code           String?        @unique
  dimension      Dimension
  subskill       String?
  questionType   QuestionType
  level          CEFRLevel
  difficulty     Int            @default(3)
  topic          String?
  prompt         String?
  instruction    String?
  correctAnswer  Json?
  explanation    String?
  estimatedTime  Int?
  tags           String[]
  status         QuestionStatus @default(DRAFT)
  exposureCount  Int            @default(0)
  version        Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  stimulusId     String?
  stimulus       QuestionStimulus? @relation(fields: [stimulusId], references: [id])
  rubricId       String?
  rubric         QuestionRubric?   @relation(fields: [rubricId], references: [id])
  authorId       String?
  reviewerId     String?
  reviewedAt     DateTime?

  options        QuestionOption[]
  sessionItems   TestSessionItem[]
  statistics     ItemStatistic[]

  @@index([dimension, level, status])
  @@index([status])
  @@index([level])
  @@index([dimension])
}

model QuestionOption {
  id         String       @id @default(uuid())
  questionId String
  question   QuestionItem @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String?
  text       String
  isCorrect  Boolean      @default(false)
  order      Int          @default(0)

  @@index([questionId])
}

model TestBlueprint {
  id                     String            @id @default(uuid())
  product                BlueprintProduct  @unique
  name                   String
  description            String?
  durationMinutes        Int               @default(60)
  defaultQuestionCount   Int               @default(25)
  dimensionWeights       Json?
  levelDistribution      Json?
  questionTypeDistribution Json?
  isActive               Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

model TestSession {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  product         String?
  targetLevel     String?
  status          SessionStatus @default(CONFIGURED)
  questionCount   Int           @default(0)
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  durationSeconds Int?
  totalScore      Float?
  cefrLevel       String?
  metadata        Json?

  sessionItems    TestSessionItem[]
  result          TestResult?

  @@index([userId, status])
  @@index([userId, startedAt])
}

model TestSessionItem {
  id                String       @id @default(uuid())
  sessionId         String
  session           TestSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId        String
  question          QuestionItem @relation(fields: [questionId], references: [id])
  order             Int
  dimension         Dimension?
  level             CEFRLevel?
  difficulty        Int?
  questionSnapshot  Json?
  maxScore          Int          @default(10)
  stage             Int?         @default(1)

  answer            UserAnswer?

  @@index([sessionId, order])
  @@index([questionId])
}

model UserAnswer {
  id            String          @id @default(uuid())
  sessionItemId String          @unique
  sessionItem   TestSessionItem @relation(fields: [sessionItemId], references: [id], onDelete: Cascade)
  userId        String
  answer        Json?
  score         Float?
  aiScore       Float?
  aiFeedback    String?
  isCorrect     Boolean?
  feedback      String?
  submittedAt   DateTime        @default(now())

  @@index([userId])
  @@index([sessionItemId])
}

model ItemStatistic {
  id                String      @id @default(uuid())
  questionId        String
  question          QuestionItem @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attempts          Int          @default(0)
  correctCount      Int          @default(0)
  accuracyRate      Float?
  avgScore          Float?
  avgTimeSeconds    Float?
  discriminationIndex Float?
  lastUsedAt        DateTime?

  @@unique([questionId])
  @@index([questionId])
}

model TestResult {
  id                String      @id @default(uuid())
  sessionId         String      @unique
  session           TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overallLevel      CEFRLevel
  overallScore      Float
  listeningScore    Float?
  readingScore      Float?
  speakingScore     Float?
  writingScore      Float?
  mediationScore    Float?
  integratedScore   Float?
  toefEquivalent    Int?
  ieltsEquivalent   Float?
  recommendations   Json?
  createdAt         DateTime    @default(now())

  certificate       Certificate?
}

model Certificate {
  id              String      @id @default(uuid())
  certificateId   String      @unique
  testResultId    String      @unique
  testResult      TestResult  @relation(fields: [testResultId], references: [id])
  userId          String
  userName        String
  overallLevel    CEFRLevel
  overallScore    Float
  issuedAt        DateTime    @default(now())
  qrCodeUrl       String?
  pdfUrl          String?
  isActive        Boolean     @default(true)
  revokedAt       DateTime?
  revokeReason    String?

  @@index([certificateId])
  @@index([userId])
}

model Waitlist {
  id          String          @id @default(uuid())
  email       String          @unique
  name        String?
  role        String?
  institution String?
  status      WaitlistStatus  @default(PENDING)
  userId      String?         @unique
  user        User?           @relation(fields: [userId], references: [id])
  invitedAt   DateTime?
  registeredAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum WaitlistStatus {
  PENDING
  INVITED
  REGISTERED
  REJECTED
}

model CanDoDescriptor {
  id          String      @id @default(uuid())
  level       CEFRLevel
  skill       Dimension
  category    String?
  descriptor  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([level, skill])
}
