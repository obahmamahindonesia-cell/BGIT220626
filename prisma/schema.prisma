generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  supabaseId    String   @unique
  email         String   @unique
  name          String?
  role          UserRole @default(TEST_TAKER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       UserProfile?
  testSessions  TestSession[]
  waitlistEntry Waitlist?
}

enum UserRole {
  TEST_TAKER
  ADMIN
}

model Question {
  id           String       @id @default(uuid())
  dimension    Dimension
  skill        String
  subskill     String?
  type         QuestionType
  level        CEFRLevel
  difficulty   Int          @default(3)
  content      Json
  rubric       Json?
  tags         String[]
  points       Int          @default(10)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  answers      Answer[]
}

enum Dimension {
  LISTENING
  READING
  SPEAKING
  WRITING
  MEDIATION
  INTEGRATED
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  ESSAY
  AUDIO_RESPONSE
  INTEGRATED_TASK
}

enum CEFRLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

model TestSession {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  status          SessionStatus @default(IN_PROGRESS)
  startedAt       DateTime      @default(now())
  finishedAt      DateTime?
  durationSeconds Int?
  questionIds     String[]

  answers         Answer[]
  result          TestResult?
}

enum SessionStatus {
  IN_PROGRESS
  SUBMITTED
  SCORED
  COMPLETED
  FAILED
}

model Answer {
  id            String      @id @default(uuid())
  sessionId     String
  session       TestSession @relation(fields: [sessionId], references: [id])
  questionId    String
  question      Question    @relation(fields: [questionId], references: [id])
  response      Json
  rawScore      Float?
  aiScore       Float?
  aiFeedback    String?
  scoredAt      DateTime?
  createdAt     DateTime    @default(now())
}

model TestResult {
  id                String      @id @default(uuid())
  sessionId         String      @unique
  session           TestSession @relation(fields: [sessionId], references: [id])

  overallLevel      CEFRLevel
  overallScore      Float

  listeningScore    Float
  readingScore      Float
  speakingScore     Float
  writingScore      Float
  mediationScore    Float
  integratedScore   Float

  toefEquivalent    Int?
  ieltsEquivalent   Float?

  recommendations   Json
  createdAt         DateTime    @default(now())

  certificate       Certificate?
}

model Waitlist {
  id          String          @id @default(uuid())
  email       String          @unique
  name        String?
  role        String?
  institution String?
  status      WaitlistStatus  @default(PENDING)
  userId      String?         @unique
  user        User?           @relation(fields: [userId], references: [id])
  invitedAt   DateTime?
  registeredAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum WaitlistStatus {
  PENDING
  INVITED
  REGISTERED
  REJECTED
}

model CanDoDescriptor {
  id          String      @id @default(uuid())
  level       CEFRLevel
  skill       Dimension
  category    String?
  descriptor  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([level, skill])
}

model UserProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])

  age                 Int?
  profession          String?
  targetLevel         String?
  testGoals           String[]
  hasPreviousTest     Boolean  @default(false)
  previousTestType    String?
  learningDuration    String?
  estimatedLevel      String?
  preferredDuration   Int      @default(60)
  practiceMode        Boolean  @default(true)
  emailNotifications  Boolean  @default(true)
  technicalCheckPassed Boolean @default(false)
  onboardingCompleted Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Certificate {
  id              String      @id @default(uuid())
  certificateId   String      @unique
  testResultId    String      @unique
  testResult      TestResult  @relation(fields: [testResultId], references: [id])
  userId          String
  userName        String
  overallLevel    CEFRLevel
  overallScore    Float
  issuedAt        DateTime    @default(now())
  qrCodeUrl       String?
  pdfUrl          String?
  isActive        Boolean     @default(true)
  revokedAt       DateTime?
  revokeReason    String?

  @@index([certificateId])
  @@index([userId])
}
